<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>墨爾本國際學生交流團・行程手冊</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@500;700;900&family=Noto+Sans+TC:wght@400;500;700&family=Roboto+Mono:wght@400;500;700&display=swap');

  :root{
    --bg: #EDF1EE;
    --bg-alt: #E3E9E4;
    --surface: #FFFFFF;
    --ink: #1D2A28;
    --ink-muted: #5C6C67;
    --line: #C9D2CC;
    --gold: #C08F35;
    --gold-soft: #F3E4C4;
    --teal: #2C6B5A;
    --teal-soft: #DCEAE4;
    --brick: #AE4A30;
    --brick-soft: #F4DED5;
    --font-display: 'Noto Serif TC', serif;
    --font-body: 'Noto Sans TC', sans-serif;
    --font-mono: 'Roboto Mono', monospace;
  }

  *{ box-sizing: border-box; }
  html,body{ margin:0; padding:0; }
  body{
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-body);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ---------- Header ---------- */
  header.hero{
    background:
      radial-gradient(ellipse at 20% -10%, rgba(192,143,53,0.18), transparent 55%),
      linear-gradient(180deg, #1D2A28 0%, #223834 100%);
    color: #F3F1EA;
    padding: 36px 20px 28px;
    position: relative;
    overflow: hidden;
  }
  header.hero::after{
    content:"";
    position:absolute; inset:0;
    background-image: repeating-linear-gradient(90deg, rgba(255,255,255,0.035) 0 1px, transparent 1px 46px);
    pointer-events:none;
  }
  .eyebrow{
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-soft);
    opacity: 0.9;
    margin-bottom: 10px;
  }
  h1{
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(26px, 6vw, 38px);
    margin: 0 0 6px;
    letter-spacing: 0.01em;
  }
  .hero-sub{
    color: #C9D6CE;
    font-size: 14.5px;
    margin: 0 0 22px;
  }

  .status-board{
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    backdrop-filter: blur(2px);
  }
  .status-dot{
    width: 10px; height:10px; border-radius:50%;
    background: var(--gold);
    box-shadow: 0 0 0 4px rgba(192,143,53,0.22);
    flex-shrink:0;
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse{
    0%,100%{ box-shadow: 0 0 0 4px rgba(192,143,53,0.22); }
    50%{ box-shadow: 0 0 0 8px rgba(192,143,53,0.08); }
  }
  .status-text b{ color: #FBEFD2; font-weight:700; }
  .status-text{ font-size: 13.5px; color:#E7E2D2; }

  /* ---------- Route strip (signature nav) ---------- */
  nav.route-wrap{
    position: sticky; top:0; z-index: 10;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    padding: 14px 12px 10px;
  }
  .route-scroll{
    display:flex;
    overflow-x:auto;
    scrollbar-width: none;
    padding: 6px 8px 14px;
    position: relative;
  }
  .route-scroll::-webkit-scrollbar{ display:none; }
  .route-line{
    position:absolute;
    left: 28px; right: 28px; top: 33px;
    height: 3px;
    background: repeating-linear-gradient(90deg, var(--line) 0 10px, transparent 10px 16px);
    z-index: 0;
  }
  .stop{
    position: relative;
    z-index: 1;
    flex: 0 0 auto;
    width: 76px;
    display:flex; flex-direction:column; align-items:center;
    gap:8px;
    background:none; border:none; cursor:pointer;
    font-family: var(--font-body);
    padding: 4px 2px;
  }
  .stop-dot{
    width: 15px; height:15px; border-radius:50%;
    background: var(--surface);
    border: 3px solid var(--line);
    transition: all .2s ease;
  }
  .stop-day{ font-family: var(--font-mono); font-size: 11px; color: var(--ink-muted); }
  .stop-date{ font-size: 12.5px; font-weight:500; color: var(--ink); }
  .stop.active .stop-dot{ background: var(--teal); border-color: var(--teal); transform: scale(1.15); }
  .stop.active .stop-day, .stop.active .stop-date{ color: var(--teal); font-weight:700; }
  .stop.today .stop-dot{
    background: var(--gold); border-color: var(--gold);
    box-shadow: 0 0 0 4px rgba(192,143,53,0.25);
  }
  .stop.today::before{
    content: "現在";
    position:absolute; top:-14px;
    font-family: var(--font-mono);
    font-size: 9.5px; color: var(--gold);
    letter-spacing: 0.05em;
  }

  /* ---------- Main content ---------- */
  main{ max-width: 720px; margin: 0 auto; padding: 22px 16px 60px; }

  .day-card{
    background: var(--surface);
    border-radius: 14px;
    border: 1px solid var(--line);
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(29,42,40,0.04);
  }
  .day-card-head{
    padding: 20px 22px 16px;
    border-bottom: 1px dashed var(--line);
  }
  .day-card-head .weekday-tag{
    display:inline-block;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--teal);
    background: var(--teal-soft);
    padding: 3px 9px;
    border-radius: 999px;
    margin-bottom: 8px;
    letter-spacing: 0.04em;
  }
  .day-card-head h2{
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    margin: 0 0 4px;
  }
  .day-card-head .place{
    color: var(--ink-muted);
    font-size: 13.5px;
  }

  .segments{ padding: 6px 22px 22px; }
  .segment{
    display:flex; gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid #F0F2EF;
  }
  .segment:last-child{ border-bottom:none; }
  .segment-label{
    flex: 0 0 62px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-muted);
    padding-top: 2px;
  }
  .segment-label .icon{ display:block; font-size: 17px; margin-bottom:4px; }
  .segment-body{ flex:1; font-size: 15px; color: var(--ink); }
  .segment.am .segment-label{ color: var(--gold); }
  .segment.pm .segment-label{ color: var(--teal); }
  .segment.eve .segment-label{ color: var(--brick); }

  .banner{
    margin-top: 14px;
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 13.5px;
    display:flex; gap:10px; align-items:flex-start;
  }
  .banner.flight{ background: var(--brick-soft); color: #7A3220; }
  .banner.gold{ background: var(--gold-soft); color: #7A5A16; }

  /* ---------- Flight plan toggle ---------- */
  .plan-toggle{
    display:flex; gap:8px;
    padding: 0 22px 4px;
    flex-wrap: wrap;
  }
  .plan-pill{
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--ink-muted);
    cursor: pointer;
    transition: all .15s ease;
  }
  .plan-pill.active{
    background: var(--teal);
    border-color: var(--teal);
    color: #fff;
    font-weight: 700;
  }
  .plan-note{
    padding: 10px 22px 0;
    font-size: 12px;
    color: var(--ink-muted);
  }

  /* ---------- Stay info ---------- */
  .stay-info{
    margin-top: 22px;
    background: var(--bg-alt);
    border-radius: 14px;
    padding: 18px 20px;
    font-size: 13.8px;
    color: var(--ink-muted);
  }
  .stay-info h3{
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .stay-info dl{ margin:0; display:grid; grid-template-columns: 76px 1fr; row-gap: 8px; column-gap: 10px; }
  .stay-info dt{ color: var(--ink); font-weight:500; }
  .stay-info dd{ margin:0; }

  footer{
    text-align:center;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--ink-muted);
    padding: 30px 16px 40px;
    opacity: 0.7;
  }

  @media (prefers-reduced-motion: reduce){
    .status-dot{ animation: none; }
  }

  /* ---------- Mobile readability tuning ---------- */
  @media (max-width: 480px){
    body{ font-size: 16px; }
    header.hero{ padding: 28px 16px 22px; }
    .hero-sub{ margin-bottom: 18px; }
    .status-board{ padding: 12px 14px; }
    .status-text{ font-size: 13px; line-height:1.5; }

    nav.route-wrap{ padding: 10px 8px 8px; }
    .stop{ width: 68px; min-height: 44px; }
    .stop-date{ font-size: 12px; }

    .day-card-head{ padding: 18px 18px 14px; }
    .day-card-head h2{ font-size: 20px; }
    .segments{ padding: 4px 18px 18px; }

    .segment{ flex-direction: column; gap: 4px; padding: 14px 0; }
    .segment-label{ flex-direction: row; align-items:center; gap:6px; }
    .segment-label .icon{ display:inline; margin-bottom:0; font-size: 15px; }
    .segment-body{ font-size: 16px; }

    .plan-toggle{ padding: 0 18px 4px; }
    .plan-pill{ padding: 9px 14px; font-size: 12.5px; min-height: 40px; }
    .plan-note{ padding: 10px 18px 0; }

    .stay-info{ padding: 16px 16px; }
    .stay-info dl{ grid-template-columns: 64px 1fr; }
  }

  /* ---------- Spot accordion ---------- */
  .spot-list{ padding: 4px 22px 22px; display:flex; flex-direction:column; gap:10px; }
  .spot{
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg);
  }
  .spot-header{
    width:100%;
    display:flex; align-items:center; justify-content:space-between;
    gap: 10px;
    padding: 13px 14px;
    background:none; border:none; cursor:pointer;
    font-family: var(--font-body);
    font-size: 14.5px;
    font-weight: 500;
    color: var(--ink);
    text-align:left;
    min-height: 44px;
  }
  .spot-header .chev{
    font-family: var(--font-mono);
    color: var(--ink-muted);
    transition: transform .2s ease;
    flex-shrink:0;
  }
  .spot.open .spot-header .chev{ transform: rotate(180deg); }
  .spot-body{
    max-height:0;
    overflow:hidden;
    transition: max-height .25s ease;
    background: var(--surface);
  }
  .spot.open .spot-body{ max-height: 600px; }
  .spot-body-inner{ padding: 4px 14px 16px; }
  .spot-block{ margin-bottom: 12px; }
  .spot-block:last-of-type{ margin-bottom: 14px; }
  .spot-block .spot-block-label{
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--teal);
    margin-bottom: 4px;
  }
  .spot-block p{ margin:0; font-size: 13.8px; color: var(--ink); }
  .spot-links{ display:flex; gap:8px; flex-wrap:wrap; }
  .spot-links a{
    font-family: var(--font-mono);
    font-size: 12px;
    text-decoration:none;
    color: var(--teal);
    background: var(--teal-soft);
    padding: 7px 11px;
    border-radius: 8px;
    min-height: 36px;
    display:inline-flex; align-items:center;
  }
  .spot-note{
    font-size: 11.5px;
    color: var(--ink-muted);
    padding: 0 22px 6px;
  }

  /* ---------- Prev/next day nav ---------- */
  .day-nav{
    display:flex; gap:10px;
    margin-top: 14px;
  }
  .day-nav button{
    flex:1;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    padding: 14px;
    border-radius: 10px;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--ink);
    cursor:pointer;
    min-height: 48px;
  }
  .day-nav button:disabled{ opacity: 0.35; cursor:default; }
  .day-nav button.primary{ background: var(--teal); border-color: var(--teal); color:#fff; }
</style>
</head>
<body>

<header class="hero">
  <div class="eyebrow">DA LI STUDY · MELBOURNE 2026</div>
  <h1>墨爾本國際學生交流團</h1>
  <p class="hero-sub">2026/07/13 — 2026/07/25 ・ 住宿地：Box Hill</p>
  <div class="status-board">
    <div class="status-dot"></div>
    <div class="status-text" id="statusText">載入中…</div>
  </div>
</header>

<nav class="route-wrap">
