    { name:"Scienceworks", photo:"互動展覽適合抓拍學生操作實驗的瞬間，大廳有自然採光，可以拍建築線條。", story:"位於 Spotswood，前身是墨爾本的抽水站，現轉型為互動科學博物館。" },
    { name:"Williamstown", photo:"海港邊適合拍夕陽跟船隻剪影，退潮時的礁石步道也是取景好地方。", story:"墨爾本最早開發的港口城鎮之一，保留許多維多利亞時期海事建築。" },
  ],
  7: [
    { name:"Hosier Lane", photo:"塗鴉每天都會更新，建議直式構圖把整面牆收進畫面，盡量避免拍到路人正臉。", story:"從 1990 年代開始，塗鴉藝術家在此輪番創作，現在是墨爾本官方認可的合法塗鴉巷弄。" },
    { name:"NGV 維多利亞國家美術館", photo:"入口大廳的水牆很適合拍倒影，館內多個展廳挑高採光佳，適合拍建築線條。", story:"National Gallery of Victoria 創立於 1861 年，是澳洲歷史最悠久、收藏最豐富的美術館。" },
  ],
  9: [
    { name:"RMIT University", photo:"Storey Hall 色彩鮮豔的立面很好拍，建議仰角拍出建築的量體感。", story:"皇家墨爾本理工大學創立於 1887 年，以建築與設計科系聞名。" },
    { name:"Melbourne Museum", photo:"中庭的森林展區挑高採光佳，適合拍人與展品互動的畫面。", story:"2000 年開幕，是南半球最大的博物館，館藏包含原住民文化與自然史。" },
  ],
};

const today = taipeiToday();
let currentIndex = DAYS.findIndex(d => d.date === today);
let statusMsg = "";

if (currentIndex === -1) {
  if (today < DAYS[0].date) {
    const diff = Math.ceil((new Date(DAYS[0].date) - new Date(today)) / 86400000);
    currentIndex = 0;
    statusMsg = `距離出發還有 <b>${diff}</b> 天`;
  } else {
    currentIndex = DAYS.length - 1;
    statusMsg = "行程已結束，感謝參加這趟交流之旅";
  }
} else {
  statusMsg = `今天是行程 <b>第 ${currentIndex + 1} 天</b>`;
}

let selectedIndex = currentIndex;

function mmdd(dateStr){
  const [,m,d] = dateStr.split("-");
  return `${parseInt(m)}/${parseInt(d)}`;
}

function renderRoute(){
  const wrap = document.getElementById('routeScroll');
  wrap.querySelectorAll('.stop').forEach(el => el.remove());
  DAYS.forEach((d, i) => {
    const btn = document.createElement('button');
    btn.className = 'stop' + (i === selectedIndex ? ' active' : '') + (d.date === today ? ' today' : '');
    btn.innerHTML = `<span class="stop-dot"></span><span class="stop-day">DAY ${i+1}</span><span class="stop-date">${mmdd(d.date)}（${d.wd}）</span>`;
    btn.addEventListener('click', () => { selectedIndex = i; render(); });
    wrap.appendChild(btn);
  });
}

function planFields(d, index){
  // Returns {place, am, pm, eve} after applying the selected flight plan's overrides, if any.
  let { place, am, pm, eve } = d;
  if (index === 0) {
    eve = FLIGHT_PLANS[selectedPlan].day0eve;
  }
  if (index === 1) {
    const p1 = FLIGHT_PLANS[selectedPlan].day1;
    place = p1.place; am = p1.am; pm = p1.pm;
  }
  return { place, am, pm, eve };
}

function renderCard(){
  const d = DAYS[selectedIndex];
  const f = planFields(d, selectedIndex);
  const card = document.getElementById('dayCard');
  const toggleHtml = d.planToggle ? `
    <div class="plan-toggle">
      ${[1,2].map(p => `<button class="plan-pill${selectedPlan === p ? ' active' : ''}" data-plan="${p}">${FLIGHT_PLANS[p].label}</button>`).join('')}
    </div>
    <div class="plan-note">機票尚未確定，以下先依你選擇的方案顯示，兩案回程航班相同（CI58）</div>
  ` : '';
  const spots = SPOTS[selectedIndex] || [];
  const spotsHtml = spots.length ? `
    <div class="spot-note">點景點名稱展開拍攝手法、景點故事跟快速連結</div>
    <div class="spot-list">
      ${spots.map((s, i) => `
        <div class="spot" data-spot="${i}">
          <button class="spot-header">${s.name}<span class="chev">⌄</span></button>
          <div class="spot-body"><div class="spot-body-inner">
            <div class="spot-block"><div class="spot-block-label">📷 拍攝手法</div><p>${s.photo}</p></div>
            <div class="spot-block"><div class="spot-block-label">📖 景點故事</div><p>${s.story}</p></div>
            <div class="spot-links">
              <a href="${mapsLink(s.name)}" target="_blank" rel="noopener">📍 Google 地圖</a>
              <a href="${transitLink(s.name)}" target="_blank" rel="noopener">🚌 大眾運輸路線</a>
            </div>
          </div></div>
        </div>
      `).join('')}
    </div>
  ` : '';
  card.innerHTML = `
    <div class="day-card-head">
      <span class="weekday-tag">DAY ${selectedIndex + 1} / ${DAYS.length}</span>
      <h2>${mmdd(d.date)}（${d.wd}）</h2>
      <div class="place">${f.place}</div>
    </div>
    ${toggleHtml}
    <div class="segments">
      <div class="segment am">
        <div class="segment-label"><span class="icon">☀️</span>上午</div>
        <div class="segment-body">${f.am}</div>
      </div>
      <div class="segment pm">
        <div class="segment-label"><span class="icon">🌇</span>下午</div>
        <div class="segment-body">${f.pm}</div>
      </div>
      <div class="segment eve">
        <div class="segment-label"><span class="icon">🌙</span>晚上</div>
        <div class="segment-body">${f.eve}</div>
      </div>
    </div>
    ${d.flight ? `<div style="padding:0 22px 20px;"><div class="banner flight">✈️ 今天有搭機行程，請提前確認證件與行李</div></div>` : ``}
    ${spotsHtml}
    <div style="padding: 4px 22px 22px;">
      <div class="day-nav">
        <button id="prevDay" ${selectedIndex === 0 ? 'disabled' : ''}>← 前一天</button>
        <button id="nextDay" class="primary" ${selectedIndex === DAYS.length - 1 ? 'disabled' : ''}>後一天 →</button>
      </div>
    </div>
  `;
  card.querySelectorAll('.plan-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      selectedPlan = parseInt(btn.dataset.plan);
      renderCard();
    });
  });
  card.querySelectorAll('.spot').forEach(el => {
    el.querySelector('.spot-header').addEventListener('click', () => {
      el.classList.toggle('open');
    });
  });
  const prevBtn = card.querySelector('#prevDay');
  const nextBtn = card.querySelector('#nextDay');
  if (prevBtn) prevBtn.addEventListener('click', () => { if (selectedIndex > 0){ selectedIndex--; render(); } });
  if (nextBtn) nextBtn.addEventListener('click', () => { if (selectedIndex < DAYS.length - 1){ selectedIndex++; render(); } });
}

function render(){
  document.getElementById('statusText').innerHTML = statusMsg;
  renderRoute();
  renderCard();
  const activeStop = document.querySelector('.stop.active');
  if (activeStop) activeStop.scrollIntoView({ inline: 'center', block: 'nearest' });
}

render();
</script>

